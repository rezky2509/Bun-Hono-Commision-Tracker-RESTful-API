    "drizzle-orm": "^1.0.0-rc.4",
    "drizzle-seed": "^0.3.1",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@scalar/hono-api-reference": "^0.11.6",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-rc.4"
  }
}